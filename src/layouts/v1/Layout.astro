---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import Navbar from '../../components/v1/Navbar.astro';
import Footer from '../../components/v1/Footer.astro';

interface Props {
	title?: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteTitle = title ? `${title} | ${t('site.title')}` : t('site.title');
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={t('site.description')} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
	</head>
	<body class="min-h-screen bg-white text-gray-900 font-sans selection:bg-blue-100">
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
