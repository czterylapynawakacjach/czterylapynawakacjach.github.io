---
import Layout from '../../../../layouts/v3/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../../i18n/utils';
import { languages } from '../../../../i18n/ui';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang, 'v3');

const posts = (await getCollection('blog', ({ id }) => {
	return id.startsWith(`${lang}/`);
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={t('nav.blog')}>
	<div class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-24">
				<h1 class="text-7xl font-serif font-black text-forest-950">
					{t('nav.blog')}
				</h1>
			</div>

			<div class="grid gap-16 grid-cols-1 md:grid-cols-2">
				{posts.map((post) => {
					const slugWithoutLang = post.id.split('/').slice(1).join('/').replace(/\.mdx$/, '').replace(/\.md$/, '');
					return (
						<article class="boutique-card group overflow-hidden flex flex-col">
							<div class="p-12">
								<p class="text-gold font-bold text-xs tracking-widest uppercase mb-4">
									{post.data.pubDate.toLocaleDateString(lang, {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</p>
								<h2 class="text-4xl font-serif font-bold text-forest-950 mb-6">
									<a href={translatePath(`blog/${slugWithoutLang}`)} class="hover:text-gold transition-colors">
										{post.data.title}
									</a>
								</h2>
								<p class="text-forest-600 font-light leading-relaxed mb-8 line-clamp-3 text-lg">
									{post.data.description}
								</p>
								<a href={translatePath(`blog/${slugWithoutLang}`)} class="text-forest-950 font-black text-xs tracking-[0.3em] uppercase group-hover:text-gold transition-colors">READ MORE →</a>
							</div>
						</article>
					);
				})}
			</div>
		</div>
	</div>
</Layout>
