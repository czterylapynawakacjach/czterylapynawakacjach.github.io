---
import Layout from '../../../layouts/v4/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const events = [
  { month: t('v4.calendar.event.may'), title: 'Dzień Pszczół', desc: t('v4.calendar.event.may.desc'), icon: '🐝' },
  { month: t('v4.calendar.event.june'), title: 'Wielkie Wirowanie', desc: t('v4.calendar.event.june.desc'), icon: '🍯' },
  { month: t('v4.calendar.event.july'), title: 'Noc w Pasiece', desc: t('v4.calendar.event.july.desc'), icon: '🌙' },
  { month: t('v4.calendar.event.august'), title: 'Warsztaty Świec', desc: t('v4.calendar.event.august.desc'), icon: '🕯️' },
];
---

<Layout title={t('v4.nav.calendar')}>
  <section class="py-40 bg-white min-h-screen overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-24">
      <h1 class="text-6xl md:text-8xl font-black text-charcoal tracking-tighter uppercase mb-8">{t('v4.calendar.title')}</h1>
      <p class="text-xl text-charcoal/60 font-bold max-w-xl italic border-l-4 border-amber pl-6">{t('v4.calendar.subtitle')}</p>
    </div>

    <!-- Horizontal Scroll Timeline -->
    <div class="relative">
      <div class="absolute top-1/2 left-0 w-full h-1 bg-charcoal/5 -translate-y-1/2 z-0"></div>
      
      <div class="flex gap-12 px-6 pb-20 overflow-x-auto no-scrollbar relative z-10 cursor-none">
        {events.map((event, i) => (
          <div class="min-w-[400px] group">
            <div class="text-[0.6rem] font-black tracking-[0.4em] text-amber mb-12 uppercase">{event.month}</div>
            
            <div class="honey-card p-12 relative group-hover:-translate-y-4 transition-all duration-500 bg-white border-4 border-charcoal">
              <div class="text-6xl mb-8 group-hover:scale-125 transition-transform duration-500 origin-left">{event.icon}</div>
              <h3 class="text-3xl font-black text-charcoal mb-6 uppercase tracking-tighter">{event.title}</h3>
              <p class="text-charcoal/60 font-bold leading-relaxed">{event.desc}</p>
              
              <!-- Pollen Burst Placeholder -->
              <div class="absolute -top-4 -right-4 w-12 h-12 bg-amber rounded-full flex items-center justify-center text-xl opacity-0 group-hover:opacity-100 group-hover:scale-150 transition-all duration-500 shadow-xl">✨</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll Hint -->
    <div class="mt-20 text-center animate-bounce">
      <span class="text-[0.6rem] font-black tracking-[0.5em] text-charcoal/20 uppercase">{t('v4.calendar.scroll')}</span>
    </div>
  </section>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
