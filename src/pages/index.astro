---
import Layout from '../layouts/PortfolioLayout.astro';
---

<Layout title="Dog Hotel Website Portfolio">
	<section class="min-h-screen flex items-center bg-gray-50 py-20 px-6">
		<div class="max-w-7xl mx-auto text-center">
			<div class="mb-16">
				<span class="text-blue-600 font-bold tracking-widest uppercase text-sm mb-4 block">Design Exploration</span>
				<h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-6">Dog Hotel Website Portfolio</h1>
				<p class="text-xl text-gray-600 max-w-2xl mx-auto">A showcase of three distinct creative directions for a modern pet boarding experience. Choose a version to explore the design and interactions.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
				<!-- v1 Card -->
				<a href="/v1/pl/" class="group block bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 text-left">
					<div class="h-40 bg-blue-600 rounded-xl mb-8 flex items-center justify-center text-white">
						<span class="text-4xl font-bold">V1</span>
					</div>
					<h2 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-blue-600 transition-colors">Clean & Classic</h2>
					<p class="text-gray-500 font-light leading-relaxed">A professional, trustworthy layout using industry-standard patterns and a calming blue palette.</p>
				</a>

				<!-- v2 Card -->
				<a href="/v2/pl/" class="group block bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 text-left">
					<div class="h-40 bg-[#1b3a2e] rounded-xl mb-8 flex items-center justify-center text-[#D4AF37]">
						<span class="text-4xl font-bold">V2</span>
					</div>
					<h2 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-[#52796F] transition-colors">Forest Boutique</h2>
					<p class="text-gray-500 font-light leading-relaxed">A high-end, nature-inspired design with luxurious typography and organic, soft elements.</p>
				</a>

				<!-- v3 Card -->
				<a href="/v3/pl/" class="group block bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 text-left">
					<div class="h-40 bg-[#0f211a] rounded-xl mb-8 flex items-center justify-center text-white relative overflow-hidden">
						<div class="absolute inset-0 opacity-20 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] bg-repeat"></div>
						<span class="text-4xl font-bold relative z-10">V3</span>
					</div>
					<h2 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-gray-600 transition-colors">Artistic & Brave</h2>
					<p class="text-gray-500 font-light leading-relaxed">An experimental, broken-grid experience with cinematic interactions and unique physics.</p>
				</a>

				<!-- v4 Card -->
				<a href="/v4/pl/" class="group block bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 text-left">
					<div class="h-40 bg-[#FFBF00] rounded-xl mb-8 flex items-center justify-center text-[#2D2D2D]">
						<span class="text-4xl font-bold">V4</span>
					</div>
					<h2 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-[#FFBF00] transition-colors">The Golden Apiary</h2>
					<p class="text-gray-500 font-light leading-relaxed">A fun, interactive artisanal experience with hexagonal grids, bee physics, and high energy.</p>
				</a>
			</div>

			<!-- Supporting Documents Section -->
			<div class="mt-32 pt-16 border-t border-gray-200">
				<h2 class="text-3xl font-bold text-gray-900 mb-12">Supporting Documents</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
					<a href="/docs/business_plan" class="px-8 py-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all text-gray-700 font-bold flex items-center justify-center gap-3">
						<span>📄</span> Business Plan
					</a>
					<a href="/docs/architecture" class="px-8 py-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all text-gray-700 font-bold flex items-center justify-center gap-3">
						<span>🏗️</span> Technical Architecture
					</a>
					<a href="/docs/umowa_hotelowa" class="px-8 py-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all text-gray-700 font-bold flex items-center justify-center gap-3">
						<span>🖋️</span> Hotel Agreement (PL)
					</a>
				</div>
			</div>

			<footer class="mt-24 pt-8 border-t border-gray-200 text-gray-400 text-sm">
				&copy; 2026 Dog Hotel Portfolio Build
			</footer>
		</div>
	</section>
</Layout>
