---
import Layout from '../../../layouts/v1/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.services')}>
	<div class="py-16 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
					{t('services.title')}
				</h1>
				<p class="mt-4 text-xl text-gray-500">
					{t('services.subtitle')}
				</p>
			</div>

			<div class="grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				<div class="bg-white rounded-lg shadow-sm p-6">
					<h3 class="text-lg font-bold text-blue-600 mb-2">{t('services.dog_boarding.title')}</h3>
					<p class="text-gray-500">{t('services.dog_boarding.desc')}</p>
				</div>
				<div class="bg-white rounded-lg shadow-sm p-6">
					<h3 class="text-lg font-bold text-blue-600 mb-2">{t('services.cat_hotel.title')}</h3>
					<p class="text-gray-500">{t('services.cat_hotel.desc')}</p>
				</div>
				<div class="bg-white rounded-lg shadow-sm p-6">
					<h3 class="text-lg font-bold text-blue-600 mb-2">{t('services.daycare.title')}</h3>
					<p class="text-gray-500">{t('services.daycare.desc')}</p>
				</div>
			</div>
		</div>
	</div>
</Layout>
