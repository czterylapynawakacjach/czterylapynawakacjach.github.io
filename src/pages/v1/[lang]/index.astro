---
import Layout from '../../../layouts/v1/Layout.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang, 'v1');
---

<Layout>
	<section class="bg-blue-600 text-white py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="text-4xl font-extrabold mb-6">{t('home.hero.title')}</h1>
			<p class="text-xl mb-8">{t('home.hero.subtitle')}</p>
			<a href={translatePath('contact')} class="inline-block bg-white text-blue-600 px-6 py-3 rounded-md font-bold hover:bg-blue-50">
				{t('home.hero.cta')}
			</a>
		</div>
	</section>

	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold mb-8">{t('home.about.title')}</h2>
			<p class="text-lg text-gray-600 mb-12">{t('home.about.text')}</p>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="p-6 border border-gray-100 rounded-lg">
					<h3 class="text-xl font-bold mb-4">{t('home.features.comfort.title')}</h3>
					<p class="text-gray-600">{t('home.features.comfort.desc')}</p>
				</div>
				<div class="p-6 border border-gray-100 rounded-lg">
					<h3 class="text-xl font-bold mb-4">{t('home.features.fun.title')}</h3>
					<p class="text-gray-600">{t('home.features.fun.desc')}</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
