---
import Layout from '../../../layouts/v1/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.pricing')}>
	<div class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl mb-12">
				{t('pricing.title')}
			</h1>
			<div class="max-w-3xl mx-auto bg-blue-50 rounded-2xl p-8 border border-blue-100">
				<div class="grid grid-cols-2 gap-4 text-left border-b border-blue-100 pb-4 mb-4 font-bold text-blue-900">
					<div>{t('pricing.header.service')}</div>
					<div class="text-right">{t('pricing.header.price')}</div>
				</div>
				<div class="space-y-4">
					<div class="grid grid-cols-2 gap-4 text-left border-b border-blue-100 py-4 text-gray-700">
						<div>{t('pricing.dog_small')}</div>
						<div class="text-right font-semibold">80 PLN / doba</div>
					</div>
					<div class="grid grid-cols-2 gap-4 text-left border-b border-blue-100 py-4 text-gray-700">
						<div>{t('pricing.dog_large')}</div>
						<div class="text-right font-semibold">100 PLN / doba</div>
					</div>
					<div class="grid grid-cols-2 gap-4 text-left border-b border-blue-100 py-4 text-gray-700">
						<div>{t('pricing.cat')}</div>
						<div class="text-right font-semibold">50 PLN / doba</div>
					</div>
					<div class="grid grid-cols-2 gap-4 text-left py-4 text-gray-700">
						<div>{t('pricing.daycare')}</div>
						<div class="text-right font-semibold">60 PLN / dzień</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
