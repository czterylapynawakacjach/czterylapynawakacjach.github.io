---
import Layout from '../../../layouts/v2/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.contact')}>
	<div class="py-24 bg-[#F8F9FA] min-h-[80vh] flex items-center">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
				<div>
					<h2 class="text-[#D4AF37] font-bold tracking-widest uppercase text-sm mb-4">{t('nav.contact')}</h2>
					<h1 class="text-5xl font-bold text-[#1b3a2e] mb-8 leading-tight">
						{t('contact.subtitle')}
					</h1>
					<p class="text-xl text-[#316a4f] font-light leading-relaxed mb-12">
						Zapraszamy do kontaktu. Nasz zespół chętnie odpowie na wszystkie Twoje pytania.
					</p>
				</div>

				<div class="bg-white p-12 rounded-3xl shadow-2xl border border-[#f1f8f5] relative overflow-hidden group">
					<form action="https://formspree.io/f/placeholder" method="POST" class="space-y-8 relative z-10">
						<div>
							<label for="name" class="block text-sm font-bold text-[#1b3a2e] mb-2 uppercase tracking-wide">{t('contact.form.name')}</label>
							<input type="text" name="name" id="name" required class="block w-full px-4 py-4 bg-[#f1f8f5] border-none rounded-2xl text-[#1b3a2e] focus:ring-2 focus:ring-[#D4AF37] transition-all duration-300" />
						</div>
						<div>
							<label for="email" class="block text-sm font-bold text-[#1b3a2e] mb-2 uppercase tracking-wide">{t('contact.form.email')}</label>
							<input type="email" name="email" id="email" required class="block w-full px-4 py-4 bg-[#f1f8f5] border-none rounded-2xl text-[#1b3a2e] focus:ring-2 focus:ring-[#D4AF37] transition-all duration-300" />
						</div>
						<div>
							<label for="message" class="block text-sm font-bold text-[#1b3a2e] mb-2 uppercase tracking-wide">{t('contact.form.message')}</label>
							<textarea name="message" id="message" rows="4" required class="block w-full px-4 py-4 bg-[#f1f8f5] border-none rounded-2xl text-[#1b3a2e] focus:ring-2 focus:ring-[#D4AF37] transition-all duration-300"></textarea>
						</div>
						<button type="submit" class="w-full py-5 px-6 border border-transparent rounded-full shadow-xl text-lg font-bold text-[#1b3a2e] bg-[#D4AF37] hover:bg-[#1b3a2e] hover:text-[#F8F9FA] focus:outline-none transition-all duration-500 group">
							<span class="animate-gentle-wag inline-block mr-2">🐾</span>
							{t('contact.form.submit')}
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</Layout>
