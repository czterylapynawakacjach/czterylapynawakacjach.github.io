---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-bold text-blue-600 mb-4">{t('site.title')}</h3>
        <p class="text-gray-500 text-sm">{t('site.description')}</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">{t('nav.contact')}</h4>
        <p class="text-gray-500 text-sm">Email: kontakt@hotel-zwierzat.pl</p>
        <p class="text-gray-500 text-sm">Tel: +48 123 456 789</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Social Media</h4>
        <div class="flex space-x-4">
          <a href="#" class="text-gray-400 hover:text-blue-500 transition-colors">Facebook</a>
          <a href="#" class="text-gray-400 hover:text-blue-500 transition-colors">Instagram</a>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-gray-200 text-center text-gray-400 text-sm">
      &copy; {currentYear} {t('site.title')}. All rights reserved.
    </div>
  </div>
</footer>
