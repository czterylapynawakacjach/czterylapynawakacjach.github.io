---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0f211a] text-[#F8F9FA]/80 pt-24 pb-12 overflow-hidden relative">
  <!-- Decorative Tree Elements -->
  <div class="absolute -top-10 left-10 opacity-5 pointer-events-none">
    <svg width="200" height="200" viewBox="0 0 100 100" fill="currentColor">
      <path d="M50 10 L20 80 L80 80 Z" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2">
        <h3 class="text-3xl font-serif font-bold text-[#D4AF37] mb-6">{t('site.title')}</h3>
        <p class="text-[#F8F9FA]/60 text-lg font-light leading-relaxed max-w-sm">
          {t('site.description')}
        </p>
      </div>
      <div>
        <h4 class="text-xs font-bold text-[#F8F9FA] uppercase tracking-widest mb-6">{t('nav.contact')}</h4>
        <ul class="space-y-4 text-sm font-light">
          <li>Email: kontakt@hotel-zwierzat.pl</li>
          <li>Tel: +48 123 456 789</li>
          <li>Adress: Leśna Droga 12, 00-001</li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-bold text-[#F8F9FA] uppercase tracking-widest mb-6">Social Media</h4>
        <div class="flex space-x-6">
          <a href="#" class="text-[#F8F9FA]/40 hover:text-[#D4AF37] transition-all duration-300">Facebook</a>
          <a href="#" class="text-[#F8F9FA]/40 hover:text-[#D4AF37] transition-all duration-300">Instagram</a>
        </div>
      </div>
    </div>
    <div class="pt-8 border-t border-[#F8F9FA]/10 flex flex-col md:flex-row justify-between items-center text-xs font-light tracking-widest uppercase">
      <p>&copy; {currentYear} {t('site.title')}. All rights reserved.</p>
    </div>
  </div>
</footer>
