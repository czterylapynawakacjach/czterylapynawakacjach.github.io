---
import metrics from '../../data/hive_metrics.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Prepare data for Chart.js
const labels = metrics.map(m => new Date(m.timestamp).toLocaleString(lang === 'pl' ? 'pl-PL' : 'en-US', { 
  month: 'short', day: 'numeric', hour: '2-digit' 
}));

const temps = metrics.map(m => m.temp);
const rains = metrics.map(m => m.rain);
const winds = metrics.map(m => m.wind);
const pressures = metrics.map(m => parseInt(m.pressure));

// Calculate Cumulative GDD
let cumulativeGDD = 0;
const gddData = metrics.map(m => {
  cumulativeGDD += m.gdd_gain;
  return cumulativeGDD;
});

// Calculate "Ghost" GDD (Historical simulation - slightly slower growth)
let ghostGDD = 0;
const ghostData = metrics.map(m => {
  ghostGDD += m.gdd_gain * 0.85;
  return ghostGDD;
});

// Daily Min/Max for Thermal Envelope
const days = [...new Set(metrics.map(m => m.date))];
const dailyMinMax = days.map(day => {
    const dayTemps = metrics.filter(m => m.date === day).map(m => m.temp);
    return {
        date: day,
        min: Math.min(...dayTemps),
        max: Math.max(...dayTemps)
    };
});

// Map envelope to all 40 points
const envelopeMin = metrics.map(m => dailyMinMax.find(d => d.date === m.date).min);
const envelopeMax = metrics.map(m => dailyMinMax.find(d => d.date === m.date).max);
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-24">
  <!-- 1. Thermal Envelope -->
  <div class="honey-card p-8 bg-white border-4 border-charcoal relative group overflow-hidden">
    <h3 class="text-xl font-black text-charcoal mb-6 uppercase italic">1. Thermal Envelope</h3>
    <div class="aspect-video w-full">
      <canvas id="thermalChart"></canvas>
    </div>
    <p class="mt-6 text-xs font-bold text-charcoal/40 uppercase tracking-widest leading-tight">Monitoring "Thermal Debt." Bees consume honey to stay above the envelope floor.</p>
  </div>

  <!-- 2. Nectar Washout -->
  <div class="honey-card p-8 bg-white border-4 border-charcoal relative group overflow-hidden">
    <h3 class="text-xl font-black text-charcoal mb-6 uppercase italic">2. Nectar Washout & Bloom</h3>
    <div class="aspect-video w-full">
      <canvas id="washoutChart"></canvas>
    </div>
    <p class="mt-6 text-xs font-bold text-charcoal/40 uppercase tracking-widest leading-tight">Rain spikes (bars) reset the flow. Plants need 48h to recharge after a washout.</p>
  </div>

  <!-- 3. Foraging Throughput -->
  <div class="honey-card p-8 bg-white border-4 border-charcoal relative group overflow-hidden">
    <h3 class="text-xl font-black text-charcoal mb-6 uppercase italic">3. Foraging Throughput</h3>
    <div class="aspect-video w-full">
      <canvas id="windChart"></canvas>
    </div>
    <p class="mt-6 text-xs font-bold text-charcoal/40 uppercase tracking-widest leading-tight">Wind > 20 km/h grounds the workforce. No flight = No income.</p>
  </div>

  <!-- 4. Barometric Panic -->
  <div class="honey-card p-8 bg-charcoal border-4 border-amber relative group overflow-hidden">
    <h3 class="text-xl font-black text-amber mb-6 uppercase italic">4. Barometric Panic Signal</h3>
    <div class="aspect-video w-full">
      <canvas id="pressureChart"></canvas>
    </div>
    <p class="mt-6 text-xs font-bold text-white/20 uppercase tracking-widest leading-tight">Sharp drops indicate storms. Grumpy bees ahead—DO NOT OPEN HIVE.</p>
  </div>

  <!-- 5. Cumulative GDD Comparison -->
  <div class="honey-card p-8 bg-white border-4 border-charcoal lg:col-span-2 relative group overflow-hidden">
    <h3 class="text-xl font-black text-charcoal mb-6 uppercase italic text-center">5. Seasonal "Ghost" GDD Comparison</h3>
    <div class="aspect-[21/9] w-full">
      <canvas id="gddChart"></canvas>
    </div>
    <p class="mt-6 text-xs font-bold text-charcoal/40 uppercase tracking-widest leading-tight text-center italic">Tracking peak flow vs last year. If current is above "Ghost", add honey supers early.</p>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline define:vars={{ labels, temps, envelopeMin, envelopeMax, rains, gddData, winds, pressures, ghostData }}>
  document.addEventListener('DOMContentLoaded', () => {
    Chart.defaults.font.family = 'Inter';
    Chart.defaults.font.weight = '900';
    Chart.defaults.color = '#2D2D2D';

    // 1. Thermal Envelope
    new Chart(document.getElementById('thermalChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Current Temp',
            data: temps,
            borderColor: '#FFBF00',
            backgroundColor: '#FFBF00',
            borderWidth: 4,
            pointRadius: 0,
            tension: 0.4,
            zIndex: 2
          },
          {
            label: 'Daily Max',
            data: envelopeMax,
            borderColor: 'rgba(0,0,0,0.05)',
            backgroundColor: 'rgba(0,0,0,0.05)',
            fill: '+1', // Fill down to Daily Min
            pointRadius: 0,
            borderWidth: 1,
            zIndex: 1
          },
          {
            label: 'Daily Min',
            data: envelopeMin,
            borderColor: 'transparent',
            backgroundColor: 'transparent',
            pointRadius: 0,
            fill: false,
            zIndex: 1
          }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: false } }, plugins: { legend: { display: false } } }
    });

    // 2. Washout
    new Chart(document.getElementById('washoutChart'), {
      data: {
        labels: labels,
        datasets: [
          { type: 'bar', label: 'Rain (mm)', data: rains, backgroundColor: '#3B82F6', order: 2 },
          { type: 'line', label: 'GDD Accumulation', data: gddData, borderColor: '#FFBF00', borderWidth: 4, yAxisID: 'y1', order: 1, tension: 0.4 }
        ]
      },
      options: { 
        responsive: true, maintainAspectRatio: false, 
        scales: { 
          y: { title: { display: true, text: 'Rain mm' } },
          y1: { position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Cumulative GDD' } }
        },
        plugins: { legend: { display: false } } 
      }
    });

    // 3. Foraging Throughput
    new Chart(document.getElementById('windChart'), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{ label: 'Wind Speed', data: winds, backgroundColor: '#2D2D2D' }]
      },
      options: { 
        responsive: true, maintainAspectRatio: false,
        plugins: { 
            legend: { display: false },
            annotation: { // Manual threshold line since we don't have the plugin loaded
                annotations: { line1: { type: 'line', yMin: 20, borderColor: 'red', borderWidth: 2 } }
            }
        },
        scales: { y: { beginAtZero: true } }
      }
    });

    // 4. Barometric Panic
    new Chart(document.getElementById('pressureChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{ label: 'Pressure', data: pressures, borderColor: '#FFBF00', borderWidth: 4, pointRadius: 0, fill: true, backgroundColor: 'rgba(255,191,0,0.1)', tension: 0.4 }]
      },
      options: { 
        responsive: true, maintainAspectRatio: false, 
        scales: { 
            x: { display: false }, 
            y: { display: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#FFBF00' } } 
        },
        plugins: { legend: { display: false } }
      }
    });

    // 5. GDD Comparison
    new Chart(document.getElementById('gddChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { label: 'Current Year', data: gddData, borderColor: '#FFBF00', borderWidth: 6, tension: 0.4 },
          { label: 'Historical Ghost', data: ghostData, borderColor: 'rgba(45,45,45,0.1)', borderWidth: 4, borderDash: [5, 5], tension: 0.4, fill: true, backgroundColor: 'rgba(45,45,45,0.02)' }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
    });
  });
</script>
