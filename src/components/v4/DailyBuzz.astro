---
import news from '../../data/news.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Sort news by category (Local first) then potentially by date if needed
const sortedNews = [...news].sort((a, b) => {
  if (a.category === 'Local' && b.category === 'Global') return -1;
  if (a.category === 'Global' && b.category === 'Local') return 1;
  return 0;
});
---

<div class="mt-24">
  <div class="mb-12">
    <h2 class="text-4xl md:text-6xl font-black text-charcoal tracking-tighter uppercase italic leading-none mb-4">{t('v4.beeops.news.title')}</h2>
    <p class="text-xl text-charcoal/60 font-bold italic border-l-4 border-amber pl-6">{t('v4.beeops.news.subtitle')}</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {sortedNews.map((item) => (
      <div class={`honey-card p-8 flex flex-col justify-between group relative overflow-hidden ${item.category === 'Local' ? 'bg-white border-amber' : 'bg-charcoal text-white border-charcoal'}`}>
        <div>
          <!-- Category Tag -->
          <div class="flex justify-between items-start mb-6">
            <span class={`px-3 py-1 rounded-full text-[0.6rem] font-black tracking-widest uppercase ${item.category === 'Local' ? 'bg-amber text-charcoal' : 'bg-white/10 text-amber'}`}>
              {item.category === 'Local' ? t('v4.beeops.news.category.local') : t('v4.beeops.news.category.global')}
            </span>
            <span class={`text-[0.6rem] font-bold uppercase tracking-widest ${item.category === 'Local' ? 'text-charcoal/40' : 'text-white/40'}`}>
              {item.source}
            </span>
          </div>

          <h3 class={`text-xl font-black mb-4 uppercase tracking-tighter leading-tight group-hover:text-amber transition-colors ${item.category === 'Local' ? 'text-charcoal' : 'text-white'}`}>
            {item.title}
          </h3>
          
          {item.summary && (
            <p class={`text-sm font-bold leading-snug mb-8 ${item.category === 'Local' ? 'text-charcoal/60' : 'text-white/60'}`}>
              {item.summary}
            </p>
          )}
        </div>

        <a 
          href={item.link} 
          target="_blank" 
          rel="noopener noreferrer"
          class={`inline-flex items-center gap-2 text-[0.6rem] font-black tracking-[0.2em] uppercase transition-all hover:gap-4 ${item.category === 'Local' ? 'text-charcoal' : 'text-amber'}`}
        >
          {t('v4.beeops.news.read_more')} <span>→</span>
        </a>

        <!-- Background Decor for Local -->
        {item.category === 'Local' && (
          <div class="absolute -bottom-4 -right-4 text-6xl opacity-5 group-hover:scale-110 transition-transform pointer-events-none">📍</div>
        )}
      </div>
    ))}
  </div>
</div>
